# ═══════════════════════════════════════════════════════════════════════════════
# AutoML LangGraph — Environment Configuration
# Copy this file to .env and fill in your values.
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Reproducibility ──────────────────────────────────────────────────────────
GLOBAL_SEED=42

# ─── LLM Provider ─────────────────────────────────────────────────────────────
# Select which LLM backend to use. Each provider requires its own API key
# and uses a different model name format (see sections below).
#
#   openai    (default) — GPT-4o, GPT-4o-mini, etc.
#   anthropic           — Claude 3.5 Sonnet, Claude 3 Haiku, etc.
#   google              — Gemini 1.5 Pro, Gemini 1.5 Flash, etc.
#
AUTOML_LLM_PROVIDER=openai

# ─── OpenAI (AUTOML_LLM_PROVIDER=openai) ─────────────────────────────────────
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
# Other valid values: gpt-4o, gpt-4-turbo, gpt-3.5-turbo

# ─── Anthropic (AUTOML_LLM_PROVIDER=anthropic) ────────────────────────────────
# Install:  pip install langchain-anthropic
# Get your key at: https://console.anthropic.com/
# ANTHROPIC_API_KEY=sk-ant-api03-...
# OPENAI_MODEL=claude-sonnet-4-20250514
# Other valid values: claude-haiku-4-5-20251001, claude-opus-4-6
# NOTE: Set OPENAI_MODEL to the Anthropic model name — the variable is shared.

# ─── Google Gemini (AUTOML_LLM_PROVIDER=google) ───────────────────────────────
# Install:  pip install langchain-google-genai
# Get your key at: https://aistudio.google.com/app/apikey
# GOOGLE_API_KEY=AIzaSy...
# OPENAI_MODEL=gemini-1.5-pro
# Other valid values: gemini-1.5-flash, gemini-2.0-flash-exp
# NOTE: Set OPENAI_MODEL to the Gemini model name — the variable is shared.

# ─── Per-agent model overrides (optional) ────────────────────────────────────
# Override the model used by individual agents. Leave blank to use OPENAI_MODEL.
# Use faster/cheaper models for routine agents, stronger ones for critical steps.
#
# EDA_MODEL=gpt-4o-mini
# LEAKAGE_MODEL=gpt-4o-mini
# FEATURE_MODEL=gpt-4o-mini
# SPLIT_MODEL=gpt-4o-mini
# MODEL_AGENT_MODEL=gpt-4o              # more capable for model selection
# EVAL_MODEL=gpt-4o-mini
# ORCHESTRATOR_MODEL=gpt-4o             # more capable for accept/retry decisions

# ─── Optuna ──────────────────────────────────────────────────────────────────
OPTUNA_TRIALS=30
OPTUNA_N_JOBS=1        # Keep 1 for SQLite safety. Set -1 to parallelise
                       # (requires a non-SQLite Optuna storage backend).

# ─── Database ────────────────────────────────────────────────────────────────
# Leave unset to let the app choose a writable SQLite location.
# AUTOML_DB_PATH=automl_history.db

# ─── Runtime store ─────────────────────────────────────────────────────────────
RUNTIME_MAX_SESSIONS=20       # Max concurrent sessions held in memory
RUNTIME_TTL_SECONDS=3600      # Evict sessions idle longer than this (seconds)

# ─── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO         # DEBUG | INFO | WARNING | ERROR
LOG_FORMAT=human       # human (pretty-print) | json (for Datadog / CloudWatch)

# ─── Deep Learning (optional) ────────────────────────────────────────────────
# TensorFlow is NOT installed by default (it's ~600 MB).
# To enable the deep_learning model candidate:
#   pip install -r requirements-dl.txt
# Then the model_agent will offer "deep_learning" as a candidate automatically
# when n_samples >= 500 and n_features >= 5.
